<build>
  <plugins>
    <!-- Shade plugin para crear el fat jar -->
    <plugin>
      <groupId>org.apache.maven.plugins</groupId>
      <artifactId>maven-shade-plugin</artifactId>
      <version>3.6.0</version> <!-- pon aquí la versión estable que uses -->
      <executions>
        <execution>
          <!-- Lo enganchamos a la fase package -->
          <phase>package</phase>
          <goals>
            <goal>shade</goal>
          </goals>
          <configuration>
            <!-- Definimos la clase con el método main -->
            <transformers>
              <transformer
                implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                <mainClass>com.ejemplo.Main</mainClass>
              </transformer>
            </transformers>
          </configuration>
        </execution>
      </executions>
    </plugin>

  </plugins>
</build>


mvn clean package

java -jar target/mi-proyecto-1.0-SNAPSHOT-shaded.jar
